---
import DesignSystemLayout from "../../layouts/DesignSystem.astro";

const primitiveScales = [
  { name: "bright", description: "Blue-tinted gray scale (slate) for light mode" },
  { name: "dim", description: "Cool neutral gray scale (zinc) for dark mode" },
  { name: "legal", description: "Amber/warning scale for legal notices" },
  { name: "brightGreen", description: "Cool emerald greens for light mode accents" },
  { name: "dimGreen", description: "Muted emerald greens for dark mode accents" },
];
---

<DesignSystemLayout seo={{ title: "Design System - Colors" }}>
  <div class="space-y-12">
    <!-- Page Description -->
    <p class="text-[var(--text-secondary)] text-lg">Primitive color scales - the foundation of the design system</p>

    <!-- Available Primitive Scales -->
    <section>
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">Available Primitive Scales</h2>
      <p class="text-[var(--text-secondary)] mb-6">Base color scales used throughout the design system</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {primitiveScales.map((scale) => (
          <div class="bg-[var(--surface-1)] rounded-lg border border-[var(--border-default)] p-4">
            <h3 class="text-lg font-bold text-[var(--text-primary)] mb-1">{scale.name}</h3>
            <p class="text-[var(--text-secondary)] text-sm">{scale.description}</p>
            <div class="mt-3 text-xs text-[var(--text-muted)] font-mono">
              --color-{scale.name}-50 to --color-{scale.name}-950
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- BrightGreen Scale -->
    <section>
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">BrightGreen Scale</h2>
      <p class="text-[var(--text-secondary)] mb-6">Cool emerald greens for light mode surfaces and accents</p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        {[50, 100, 200, 300, 400, 500, 600, 700, 800, 900, 950].map((shade) => (
          <div class="bg-[var(--surface-1)] rounded-lg border border-[var(--border-default)] overflow-hidden">
            <div 
              class="h-24 w-full"
              style={`background-color: var(--color-brightGreen-${shade})`}
            />
            <div class="p-3 space-y-1">
              <div class="text-sm font-mono font-bold text-[var(--text-primary)]">brightGreen-{shade}</div>
              <div class="text-xs text-[var(--text-muted)] font-mono">--color-brightGreen-{shade}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- DimGreen Scale -->
    <section>
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">DimGreen Scale</h2>
      <p class="text-[var(--text-secondary)] mb-6">Muted emerald greens for dark mode surfaces and accents</p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        {[50, 100, 200, 300, 400, 500, 600, 700, 800, 900, 950].map((shade) => (
          <div class="bg-[var(--surface-1)] rounded-lg border border-[var(--border-default)] overflow-hidden">
            <div 
              class="h-24 w-full"
              style={`background-color: var(--color-dimGreen-${shade})`}
            />
            <div class="p-3 space-y-1">
              <div class="text-sm font-mono font-bold text-[var(--text-primary)]">dimGreen-{shade}</div>
              <div class="text-xs text-[var(--text-muted)] font-mono">--color-dimGreen-{shade}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Legal (Amber) Scale -->
    <section>
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">Legal Scale</h2>
      <p class="text-[var(--text-secondary)] mb-6">Amber/warning colors for legal notices and warnings</p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        {[50, 100, 200, 300, 400, 500, 600, 700, 800, 900, 950].map((shade) => (
          <div class="bg-[var(--surface-1)] rounded-lg border border-[var(--border-default)] overflow-hidden">
            <div 
              class="h-24 w-full"
              style={`background-color: var(--color-legal-${shade})`}
            />
            <div class="p-3 space-y-1">
              <div class="text-sm font-mono font-bold text-[var(--text-primary)]">legal-{shade}</div>
              <div class="text-xs text-[var(--text-muted)] font-mono">--color-legal-{shade}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Usage Examples -->
    <section>
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">Usage Examples</h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <h3 class="font-bold text-[var(--text-secondary)]">Tailwind Classes</h3>
          <div class="bg-[var(--surface-1)] p-4 rounded-lg font-mono text-sm text-[var(--text-primary)] space-y-2 border border-[var(--border-default)]">
            <div>bg-bright-500</div>
            <div>bg-dim-300</div>
            <div>text-legal-600</div>
            <div>bg-brightGreen-500</div>
            <div>text-dimGreen-400</div>
          </div>
        </div>
        
        <div class="space-y-4">
          <h3 class="font-bold text-[var(--text-secondary)]">CSS Variables</h3>
          <div class="bg-[var(--surface-1)] p-4 rounded-lg font-mono text-sm text-[var(--text-primary)] space-y-2 border border-[var(--border-default)]">
            <div>var(--color-bright-500)</div>
            <div>var(--color-dim-300)</div>
            <div>var(--color-legal-600)</div>
            <div>var(--color-brightGreen-500)</div>
            <div>var(--color-dimGreen-400)</div>
          </div>
        </div>
      </div>
    </section>
  </div>
</DesignSystemLayout>
