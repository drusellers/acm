---
import DesignSystemLayout from "../../layouts/DesignSystem.astro";
import FontCard from "../../components/DesignSystem/FontCard.astro";
import FontSizeCard from "../../components/DesignSystem/FontSizeCard.astro";

// Tailwind default font sizes
const fontSizes = [
  { name: "text-xs", size: "0.75rem", lineHeight: "1rem" },
  { name: "text-sm", size: "0.875rem", lineHeight: "1.25rem" },
  { name: "text-base", size: "1rem", lineHeight: "1.5rem" },
  { name: "text-lg", size: "1.125rem", lineHeight: "1.75rem" },
  { name: "text-xl", size: "1.25rem", lineHeight: "1.75rem" },
  { name: "text-2xl", size: "1.5rem", lineHeight: "2rem" },
  { name: "text-3xl", size: "1.875rem", lineHeight: "2.25rem" },
  { name: "text-4xl", size: "2.25rem", lineHeight: "2.5rem" },
  { name: "text-5xl", size: "3rem", lineHeight: "1" },
  { name: "text-6xl", size: "3.75rem", lineHeight: "1" },
  { name: "text-7xl", size: "4.5rem", lineHeight: "1" },
  { name: "text-8xl", size: "6rem", lineHeight: "1" },
  { name: "text-9xl", size: "8rem", lineHeight: "1" },
];

// Font weights
const fontWeights = [
  { name: "font-thin", weight: 100 },
  { name: "font-extralight", weight: 200 },
  { name: "font-light", weight: 300 },
  { name: "font-normal", weight: 400 },
  { name: "font-medium", weight: 500 },
  { name: "font-semibold", weight: 600 },
  { name: "font-bold", weight: 700 },
  { name: "font-extrabold", weight: 800 },
  { name: "font-black", weight: 900 },
];

const sampleText = "The quick brown fox jumps over the lazy dog.";
---

<DesignSystemLayout seo={{ title: "Design System - Typography" }}>
  <div class="space-y-12">
    <!-- Page Description -->
    <p class="text-(--text-secondary) text-lg">Typography reference and guidelines</p>

    <!-- Font Families Overview -->
    <section>
      <h2 class="text-2xl font-bold text-(--text-primary) mb-6">Font Families</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Outfit Variable (Headings) -->
          <FontCard title="Body text font" fontFamily="'Outfit Variable', sans-serif" weights="100-900" />


        <!-- Open Sans Variable (Body) -->
          <FontCard title="Headings font" fontFamily="'Open Sans Variable', sans-serif" weights="300-800" />
      </div>
    </section>

    <!-- Font Sizes Side by Side -->
    <section>
      <h2 class="text-2xl font-bold text-(--text-primary) mb-4">Font Sizes</h2>
      <p class="text-(--text-secondary) mb-6">Compare font sizes side by side</p>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Column 1: Outfit Variable -->
        <div class="space-y-6">
          <h3 class="text-lg font-medium text-(--text-primary) border-b border-(--border-default) pb-2">Outfit Variable</h3>
          {fontSizes.map((size) => (
              <FontSizeCard name={size.name} size={size.size} lineHeight={size.lineHeight} fontFamily="'Outfit Variable', sans-serif" sampleText={sampleText} />
          ))}
        </div>
        
        <!-- Column 2: Open Sans Variable -->
        <div class="space-y-6">
          <h3 class="text-lg font-medium text-(--text-primary) border-b border-(--border-default) pb-2">Open Sans Variable</h3>
          {fontSizes.map((size) => (
                  <FontSizeCard name={size.name} size={size.size} lineHeight={size.lineHeight} fontFamily="'Open Sans Variable', sans-serif" sampleText={sampleText} />
          ))}
        </div>
      </div>
    </section>

    <!-- Usage Examples -->
    <section>
      <h2 class="text-2xl font-bold text-(--text-primary) mb-6">Usage Examples</h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <h3 class="font-bold text-(--text-secondary)">Tailwind Classes</h3>
          <div class="bg-(--surface-2) p-4 rounded-lg font-mono text-sm text-(--text-primary) space-y-2">
            <div>text-4xl font-bold</div>
            <div>text-lg font-medium</div>
            <div>text-sm font-normal</div>
            <div>text-xs font-light</div>
          </div>
        </div>
        
        <div class="space-y-4">
          <h3 class="font-bold text-(--text-secondary)">CSS Custom Properties</h3>
          <div class="bg-(--surface-2) p-4 rounded-lg font-mono text-sm text-(--text-primary) space-y-2">
            <div>font-family: var(--font-headings);</div>
            <div>font-family: var(--font-sans);</div>
          </div>
        </div>
      </div>

      <div class="mt-8 bg-(--surface-1) rounded-lg border border-(--border-default) p-6">
        <h3 class="font-bold text-(--text-primary) mb-4">Theme Configuration</h3>
        <pre class="bg-(--surface-2) p-4 rounded-lg overflow-x-auto text-sm"><code class="text-(--text-primary)">@theme {'{'}
  --font-sans: "Open Sans Variable";
  --font-headings: "Outfit Variable";
{'}'}</code></pre>
      </div>
    </section>
  </div>
</DesignSystemLayout>
