---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const allTerms: CollectionEntry<"glossary">[] = await getCollection("glossary");

// Sort alphabetically by label
const sortedTerms = allTerms.sort((a, b) => a.data.label.localeCompare(b.data.label));
---

<Layout>
    <h1 class="text-3xl font-bold mb-8 dark:text-dim-300">Glossary</h1>

    <div class="grid gap-4">
        {sortedTerms.map((term) => (
            <a
                href={`/glossary/${term.id}`}
                class="p-4"
            >
                <h2 class="text-xl font-semibold">{term.data.label}</h2>
            </a>
        ))}
    </div>
</Layout>
