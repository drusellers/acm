---
import Logo from "../assets/acm.svg";
import BookACallButton from "./BookACallButton.astro";

const height = 25
const width = (79/10) * height
---
<div class="flex justify-between">
    <div class="flex flex-col">
        <h1 class="text-3xl text-blue-300">
            <a href="/" class="text-black dark:text-white" alt="A Curious Mind Logo">
                 <Logo height={height} width={width} />
                <!--A Curious Mind-->
            </a>
        </h1>
        <div class="text-xs flex">
            <span class="text-figment-400">the professional side of</span>
            <a target="_blank" href="https://drusellers.com" class="ml-[1ch]">
                <!--<Image src={sig} alt="Dru Sellers" height="30"/>-->
                Dru Sellers
            </a>
        </div>
    </div>
    <div class="flex space-x-2 items-center">
        <button 
            id="theme-toggle"
            class="p-2 rounded-md text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-1)] transition-colors"
            aria-label="Toggle dark mode"
        >
            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
        </button>
        <BookACallButton />
    </div>
</div>

<script>
    const toggleBtn = document.getElementById('theme-toggle');
    const html = document.documentElement;
    
    toggleBtn?.addEventListener('click', () => {
        html.classList.toggle('dark');
        const newTheme = html.classList.contains('dark') ? 'dark' : 'light';
        localStorage.setItem('theme', newTheme);
    });
</script>